# Birdeye API key(s). One key, or comma-separated list for rotation (e.g. key1,key2,key3).
# API_KEY=your_birdeye_api_key
# API_KEYS=key1,key2,key3

# Optional. Port for local dev (default 3001).
# PORT=3001


# Leave unset for local dev (all origins allowed).
# CORS_ORIGIN=https://myapp.railway.app

# Optional. Rate limit: max requests per IP per time window. Default: 30 per 60 seconds.
# RATE_LIMIT_MAX=30
# RATE_LIMIT_WINDOW_MS=60000
